# URL backendu (domyślnie http://localhost:5000/api/v1)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# MSW: w .env.development domyślnie false (prawdziwe API). true = mocki bez Dockera
# VITE_USE_MOCKS=false

# Czy pokazywać kafelki szybkiego logowania w środowisku testowym (true/false)
VITE_SHOW_QUICK_LOGIN=true

# ngrok — tunel HTTPS pod test skanera QR na telefonie (pnpm dev:mobile)
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
